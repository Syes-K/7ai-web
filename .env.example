# 数据库（二选一）
# - 本地开发：不设置 DATABASE_URL，默认 SQLite（data/app.db）
# - 生产/远程：设置 DATABASE_URL 使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/sevenai
# DATABASE_SSL=1
# SQLITE_PATH=./data/app.db

# 打开 TypeORM SQL 日志（调试）
# TYPEORM_LOGGING=1

# 管理员用户名
ADMIN_USER=admin@example.com

# 模型配置密钥
MODEL_CONFIG_SECRET=your-secret-key

# 系统默认的对话模型提供商
CHAT_LLM_PROVIDER=your-chat-provider

# 系统默认的对话模型
CHAT_LLM_MODEL=your-chat-model

# 系统默认的对话 API Key（与 CHAT_LLM_PROVIDER / CHAT_LLM_MODEL 配合）
CHAT_LLM_API_KEY=your-chat-llm-api-key

# 系统默认的向量模型提供商
EMBEDDING_LLM_PROVIDER=your-embedding-provider

# 系统默认的向量模型
EMBEDDING_LLM_MODEL=your-embedding-model

# 系统默认的向量 API Key
EMBEDDING_API_KEY=your-embedding-api-key

# MCP 凭证主密钥
MCP_CREDENTIALS_MASTER_KEY=your-mcp-credentials-master-key

# OpenAI API Key
OPENAI_API_KEY_NEW=your-openai-api-key-new

# Skill Pack 意图路由 LLM 调用超时（毫秒）；可被 SKILL_PACK_INTENT_TIMEOUT_MS 覆盖
SKILL_PACK_INTENT_TIMEOUT_MS=15000