# SQLite 数据库文件路径（默认：项目根目录下 data/app.db）
# SQLITE_PATH=./data/app.db

# 打开 TypeORM SQL 日志（调试）
# TYPEORM_LOGGING=1

# 管理员用户名
ADMIN_USER=admin@example.com

# 模型配置密钥
MODEL_CONFIG_SECRET=your-secret-key

# 系统默认的对话模型提供商
CHAT_LLM_PROVIDER=your-chat-provider

# 系统默认的对话模型
CHAT_LLM_MODEL=your-chat-model

# 系统默认的对话 API Key（与 CHAT_LLM_PROVIDER / CHAT_LLM_MODEL 配合）
CHAT_LLM_API_KEY=your-chat-llm-api-key

# 系统默认的向量模型提供商
EMBEDDING_LLM_PROVIDER=your-embedding-provider

# 系统默认的向量模型
EMBEDDING_LLM_MODEL=your-embedding-model

# 系统默认的向量 API Key
EMBEDDING_API_KEY=your-embedding-api-key